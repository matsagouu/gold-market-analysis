        "# 1) Κάνε το sp500 \"flat\" (μονή στήλη)\n",
        "sp500_series = sp500[(\"SP500\", \"^GSPC\")].rename(\"SP500\")\n",
        "\n",
        "# 2) Βεβαιώσου ότι είναι DataFrame\n",
        "sp500_df = sp500_series.to_frame()\n",
        "\n",
        "# 3) Ετοίμασε το gold (index = Date)\n",
        "gold = df[[\"Date\", \"Close\"]].copy()\n",
        "gold[\"Date\"] = pd.to_datetime(gold[\"Date\"], format=\"%d-%m-%y\")\n",
        "gold = gold.sort_values(\"Date\")\n",
